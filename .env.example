# Sanity CMS
# Get these from https://sanity.io/manage → your project → Settings → API
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity API token (read + write) — needed only for the migration script
# Create at: Sanity manage → API → Tokens → Add API token (Editor role)
# NEVER commit this token to git
SANITY_API_TOKEN=your_token_here
